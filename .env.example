# Backend database
DATABASE_URL=postgresql+asyncpg://urbanus:urbanus@localhost:5432/urbanus

# Frontend proxy target for same-origin API routes
PYTHON_API_URL=http://localhost:8000

# Frontend street data proxy targets, tried in order
OVERPASS_API_URLS=https://overpass-api.de/api/interpreter,https://overpass.kumi.systems/api/interpreter
OVERPASS_USER_AGENT=Urbanus/0.1 (+https://github.com/rckbrcls/urbanus)

# Optional elevation provider
OPENTOPOGRAPHY_API_KEY=replace-with-your-api-key
